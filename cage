#!/usr/bin/env bash
#
# cage — drop any directory into a throwaway Docker container and run Claude Code
#        recklessly (--dangerously-skip-permissions) without risking your Mac.
#
# Type `cage` in a project directory:
#   1. detect the project's toolchain (node/ruby/python/go/rust…)
#   2. build/reuse a cached image with those runtimes
#   3. copy your working tree (incl. uncommitted changes) into an EPHEMERAL container
#   4. launch Claude Code with --dangerously-skip-permissions
#   5. on exit, rescue any unpushed work (push / shell / patch) before tearing down
#
# Your host disk is NEVER bind-mounted. The agent works on a copy; work gets out by
# `git push` (primary) or the rescue patch/bundle. See README.md.
#
# Self-contained & portable: clone anywhere, `cp cage.config.example cage.config`,
# symlink `cage` onto your $PATH, run `cage` from any project.
set -euo pipefail

# --- Resolve our REAL location, even when invoked via a symlink on $PATH ---------------
SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# Per-machine secrets & prefs live next to this script (gitignored). The script "phones
# home" to its own install dir for config no matter which directory you run it from.
[[ -f "$HERE/cage.config" ]] && source "$HERE/cage.config"

source "$HERE/lib/detect.sh"

# --- Tunables (override in cage.config) ------------------------------------------------
CLAUDE_VOLUME="${CAGE_CLAUDE_VOLUME:-cage_claude}"   # shared Claude login (auth once)
CLAUDE_DIR="/home/cage/.cage-claude"                 # CLAUDE_CONFIG_DIR inside the image
NODE_MAJOR="${CAGE_NODE_MAJOR:-22}"                  # base Node (for Claude Code itself)
PREINSTALL="${CAGE_PREINSTALL:-1}"                   # pre-install detected deps before Claude
SYNC_GLOBAL_CLAUDE="${CAGE_SYNC_GLOBAL_CLAUDE:-1}"   # copy ~/.claude/CLAUDE.md + skills in
SYNC_SETTINGS="${CAGE_SYNC_SETTINGS:-0}"             # also copy ~/.claude/settings.json (off: hooks/paths)
# Heavy, reinstallable dirs kept OUT of the copy (the agent reinstalls them):
COPY_EXCLUDES="${CAGE_COPY_EXCLUDES:-node_modules .venv venv vendor/bundle .bundle target .next .nuxt __pycache__ .pytest_cache .gradle .DS_Store}"
BREADCRUMB="${CAGE_BREADCRUMB:-1}"                   # leave a .cage note of what each session did
NOTE_FILE="${CAGE_NOTE_FILE:-.cage}"                 # breadcrumb filename in the project dir
PORTS="${CAGE_PORTS:-4000}"                          # host port(s) to publish (space-separated; "" = none)

# Injected into the agent (via --append-system-prompt) so it reads/updates the breadcrumb.
SYS_NOTE="You are running inside \"cage\", a throwaway Docker container — run commands freely; the host machine is safe and unaffected. A file at /work/${NOTE_FILE} records what previous cage sessions did in this directory. Read it first for context. Before you finish, append a short dated entry to /work/${NOTE_FILE} summarizing what you did and any follow-ups, formatted as:

## <date>
_<one to three sentence summary; note any TODOs or next steps>_"

# --- Pretty output (all to stderr, so command substitutions capture only return values) ---
log()  { printf '\033[1;36m▶ %s\033[0m\n' "$*" >&2; }
warn() { printf '\033[1;33m! %s\033[0m\n' "$*" >&2; }
die()  { printf '\033[1;31m✗ %s\033[0m\n' "$*" >&2; exit 1; }

sha() { if command -v shasum >/dev/null 2>&1; then shasum -a 256; else sha256sum; fi | awk '{print $1}'; }

need_docker() {
  command -v docker >/dev/null 2>&1 || die "Docker not found. Install Docker Desktop and try again."
  docker info >/dev/null 2>&1 || die "Docker daemon not reachable. Is Docker Desktop running?"
}

# Set/replace an `export VAR="value"` line in cage.config (used by token importers).
set_config() {
  local var="$1" val="$2" cfg="$HERE/cage.config"
  touch "$cfg"
  { grep -vE "^[[:space:]]*export[[:space:]]+${var}=" "$cfg" || true; } > "$cfg.tmp"
  mv "$cfg.tmp" "$cfg"
  printf 'export %s="%s"\n' "$var" "$val" >> "$cfg"
}

# --- Project identity -----------------------------------------------------------------
PROJ="$PWD"
proj_name() { basename "$PROJ" | tr -c 'a-zA-Z0-9_.-' '_'; }
proj_hash() { printf '%s' "$PROJ" | sha | cut -c1-8; }

# Image tag = hash of (detected runtimes + base node + Dockerfile + entrypoint), so projects
# with an identical stack share one cached image; editing the template rebuilds.
image_tag() {
  local runtimes="$1" manifest
  manifest="runtimes=$runtimes;node=$NODE_MAJOR;$(cat "$HERE/templates/Dockerfile" "$HERE/templates/entrypoint.sh" | sha)"
  printf 'cage:%s' "$(printf '%s' "$manifest" | sha | cut -c1-12)"
}

image_exists() { docker image inspect "$1" >/dev/null 2>&1; }

build_image() {
  local tag="$1" runtimes="$2"
  log "Building image ${tag}  (runtimes: ${runtimes:-<base only>})"
  DOCKER_BUILDKIT=1 docker build \
    --build-arg CAGE_RUNTIMES="$runtimes" \
    --build-arg NODE_MAJOR="$NODE_MAJOR" \
    -t "$tag" "$HERE/templates"
}

ensure_image() {
  local runtimes tag
  runtimes="$(detect_runtimes "$PROJ")"
  tag="$(image_tag "$runtimes")"
  image_exists "$tag" || build_image "$tag" "$runtimes"
  printf '%s' "$tag"
}

# --- Claude auth (one-time; persists in the shared volume) -----------------------------
# The base image is enough to run Claude for login; build it if it doesn't exist yet.
ensure_base_image() {
  local base; base="$(image_tag "")"
  image_exists "$base" || build_image "$base" ""
  printf '%s' "$base"
}

# True if the shared volume already holds Claude credentials (.credentials.json).
volume_has_login() {
  docker volume inspect "$CLAUDE_VOLUME" >/dev/null 2>&1 || return 1
  docker run --rm --entrypoint test -v "${CLAUDE_VOLUME}:/c" "$1" -s /c/.credentials.json
}

# Explicit login session (used by `cage login` and `cage setup`). Normal `cage` runs don't
# need this — Claude prompts for login inline on first use and persists it to the volume.
do_login() {
  local base="$1"
  log "Launching Claude for a one-time login → pick 'Claude account with subscription', then /exit when done."
  docker run --rm -it -v "${CLAUDE_VOLUME}:${CLAUDE_DIR}" "$base" bash -lc 'claude' || true
}

# Returns 0 if Claude is ready to auth without prompting (API key set, or volume has a login).
have_login() {
  [[ -n "${ANTHROPIC_API_KEY:-}" ]] && return 0
  docker volume inspect "$CLAUDE_VOLUME" >/dev/null 2>&1
}

# --- The container lifecycle ----------------------------------------------------------
CID=""
START_SHA=""        # /work HEAD at spin-up, to scope "this session's" commits
NOTE_BEFORE="none"  # hash of /work/.cage at spin-up, to tell if the agent updated it
cleanup() { [[ -n "$CID" ]] && docker rm -f "$CID" >/dev/null 2>&1 || true; }
trap cleanup EXIT

# Append a breadcrumb to /work/.cage and copy it back to the host. If the agent already added
# a dated entry this session, just append cage's mechanical one-liner under it (merged look);
# otherwise write a self-contained entry. Skips entirely when nothing happened.
write_breadcrumb() {
  [[ "$BREADCRUMB" == 1 && -n "$CID" ]] || return 0
  local facts after agent_wrote
  facts="$(docker exec "$CID" bash -lc '
    cd /work || exit 0
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    range="HEAD"; [ -n "'"$START_SHA"'" ] && range="'"$START_SHA"'..HEAD"
    commits=$(git log --oneline $range 2>/dev/null)
    n=$(printf "%s\n" "$commits" | grep -c . )
    shas=$(printf "%s\n" "$commits" | awk "{print \$1}" | head -3 | paste -sd, -)
    files=$(git diff --name-only $range 2>/dev/null | grep -c . )
    pushed=$(git branch -r --contains HEAD 2>/dev/null | head -1)
    if [ "$n" -gt 0 ]; then
      if [ -n "$pushed" ]; then echo "pushed $branch ($(git rev-parse --short HEAD)); $n commit(s), $files file(s)"
      else echo "$n commit(s) NOT pushed ($shas); $files file(s)"; fi
    fi
  ' 2>/dev/null || true)"

  after="$(docker exec "$CID" bash -lc "cd /work && [ -f '$NOTE_FILE' ] && sha256sum '$NOTE_FILE' | cut -d' ' -f1 || echo none" 2>/dev/null || echo none)"
  [[ "$after" != "$NOTE_BEFORE" ]] && agent_wrote=1 || agent_wrote=0

  # Nothing committed and the agent left no note → don't clutter the file.
  [[ -z "$facts" && "$agent_wrote" == 0 ]] && return 0

  local ts; ts="$(date '+%Y-%m-%d %H:%M')"
  docker exec "$CID" bash -lc "
    cd /work || exit 0
    if [ '$agent_wrote' = '0' ]; then printf '\n## %s\n' '$ts' >> '$NOTE_FILE'; fi
    [ -n \"\$1\" ] && printf -- '— cage: %s\n' \"\$1\" >> '$NOTE_FILE'
    true
  " bash "$facts" || true

  docker cp "$CID:/work/$NOTE_FILE" "$PROJ/$NOTE_FILE" >/dev/null 2>&1 \
    && log "📓 Updated $PROJ/$NOTE_FILE" || true

  # Keep the host copy out of git too (repo root may be a parent of this dir).
  local root; root="$(git -C "$PROJ" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -n "$root" && -d "$root/.git" ]]; then
    grep -qxF "$NOTE_FILE" "$root/.git/info/exclude" 2>/dev/null || echo "$NOTE_FILE" >> "$root/.git/info/exclude"
  fi
}

# spin_up <image-tag>  -> sets global CID to a started container with code copied in
spin_up() {
  local tag="$1"
  local name="cage_$(proj_name)_$(proj_hash)"
  docker rm -f "$name" >/dev/null 2>&1 || true   # clear any stale container for this dir

  # Publish cage's port(s) to the host (bound to localhost only — not exposed to your LAN).
  # PORT is set to the first so frameworks that honor it pick it up automatically.
  local p; local pargs=(); local first="${PORTS%% *}"
  for p in $PORTS; do pargs+=( -p "127.0.0.1:$p:$p" ); done

  log "Creating ephemeral container from ${tag}"
  CID="$(docker create \
    --name "$name" \
    --hostname "cage" \
    -w /work \
    ${pargs[@]+"${pargs[@]}"} \
    -v "${CLAUDE_VOLUME}:${CLAUDE_DIR}" \
    -e ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}" \
    -e GH_TOKEN="${GH_TOKEN:-}" \
    -e GIT_USER_NAME="${GIT_USER_NAME:-}" \
    -e GIT_USER_EMAIL="${GIT_USER_EMAIL:-}" \
    ${first:+-e PORT="$first"} \
    "$tag" sleep infinity)"

  log "Copying working tree into the container (host disk untouched)…"
  # Bare patterns (no leading */) match at any depth on both bsdtar and GNU tar.
  local n; local excl=()
  for n in $COPY_EXCLUDES; do excl+=( --exclude="$n" ); done
  # macOS bsdtar embeds extended attributes (com.apple.metadata:*, resource forks) by
  # default. The Linux container rejects them on extract (lsetxattr … operation not
  # supported), which aborts the whole copy ("Successfully copied 0B"). Strip them when
  # the local tar supports it; both flags are harmless / a no-op on GNU tar (Linux host).
  local meta=()
  tar --no-xattrs       --version >/dev/null 2>&1 && meta+=( --no-xattrs )
  tar --no-mac-metadata --version >/dev/null 2>&1 && meta+=( --no-mac-metadata )
  tar -C "$PROJ" ${meta[@]+"${meta[@]}"} ${excl[@]+"${excl[@]}"} -cf - . | docker cp - "$CID:/work"

  docker start "$CID" >/dev/null   # entrypoint chowns /work + sets git identity / GH_TOKEN

  # Guarantee /work is a git repo so the agent can always commit (no host changes). Dirs that
  # are repo roots already brought their .git; subdirs / non-repos get a fresh one here.
  docker exec "$CID" bash -lc 'cd /work && [ -d .git ] || git init -q' || true

  # Breadcrumb (.cage): keep it out of git, record session start state, and show prior notes.
  if [[ "$BREADCRUMB" == 1 ]]; then
    docker exec "$CID" bash -lc "cd /work && mkdir -p .git/info && grep -qxF '$NOTE_FILE' .git/info/exclude 2>/dev/null || echo '$NOTE_FILE' >> .git/info/exclude" || true
    START_SHA="$(docker exec "$CID" bash -lc 'cd /work && git rev-parse HEAD 2>/dev/null' || true)"
    NOTE_BEFORE="$(docker exec "$CID" bash -lc "cd /work && [ -f '$NOTE_FILE' ] && sha256sum '$NOTE_FILE' | cut -d' ' -f1 || echo none" 2>/dev/null || echo none)"
    if [[ -f "$PROJ/$NOTE_FILE" ]]; then
      log "📓 Previous cage notes for this dir (tail):"
      tail -n 15 "$PROJ/$NOTE_FILE" | sed 's/^/    /'
    fi
  fi

  sync_global_claude

  if [[ "$PREINSTALL" == 1 ]]; then
    local cmds; cmds="$(detect_install "$PROJ")"
    if [[ -n "$cmds" ]]; then
      log "Pre-installing detected dependencies…"
      docker exec "$CID" bash -lc "set +e; cd /work; $cmds" || warn "Some deps failed to install — the agent can finish them inside."
    fi
  fi
}

sync_global_claude() {
  [[ "$SYNC_GLOBAL_CLAUDE" == 1 ]] || return 0
  local src="$HOME/.claude"
  [[ -f "$src/CLAUDE.md" ]] && docker cp "$src/CLAUDE.md" "$CID:$CLAUDE_DIR/CLAUDE.md" >/dev/null 2>&1 || true
  [[ -d "$src/skills"   ]] && docker cp "$src/skills"   "$CID:$CLAUDE_DIR/"          >/dev/null 2>&1 || true
  if [[ "$SYNC_SETTINGS" == 1 && -f "$src/settings.json" ]]; then
    docker cp "$src/settings.json" "$CID:$CLAUDE_DIR/settings.json" >/dev/null 2>&1 || true
  else
    # Don't copy the whole host settings.json (its hooks/paths don't apply in-container), but
    # always disable commit/PR attribution so the in-cage agent never claims credit for your work.
    local nocredit='{"includeCoAuthoredBy":false,"attribution":{"commit":"","pr":""}}'
    docker exec -i -u root "$CID" bash -lc "cat > '$CLAUDE_DIR/settings.json'" <<<"$nocredit" >/dev/null 2>&1 || true
  fi
  docker exec -u root "$CID" chown -R cage:cage "$CLAUDE_DIR" >/dev/null 2>&1 || true
}

# rescue_work — before teardown, never silently eat work that lives only in the container.
rescue_work() {
  local dirty unpushed
  dirty="$(docker exec "$CID" bash -lc 'cd /work && git status --porcelain 2>/dev/null' || true)"
  unpushed="$(docker exec "$CID" bash -lc 'cd /work && git log --branches --not --remotes --oneline 2>/dev/null' || true)"
  if [[ -z "$dirty" && -z "$unpushed" ]]; then
    log "All work is pushed (or there was none) — tearing the cage down."
    return 0
  fi

  warn "This cage has work that exists ONLY inside the container:"
  if [[ -n "$unpushed" ]]; then echo "  Unpushed commits:";    echo "$unpushed" | sed 's/^/    /'; fi
  if [[ -n "$dirty"    ]]; then echo "  Uncommitted changes:"; echo "$dirty"    | sed 's/^/    /'; fi
  echo
  while true; do
    printf '  Rescue: [p]ush  [s]hell  [d]ump patch+bundle to host  [q]uit & discard ? '
    local ans=""; read -r ans </dev/tty || ans=q
    case "$ans" in
      p) if docker exec -it "$CID" bash -lc 'cd /work && git push -u origin HEAD'; then break
         else warn "Push failed (no remote / no GH_TOKEN?). Try [d] to dump it locally."; fi ;;
      s) docker exec -it "$CID" bash -lc 'cd /work && echo "(exit the shell to return to the rescue menu)" && exec bash' || true ;;
      d) dump_rescue; break ;;
      q) warn "Discarding the container's work."; break ;;
      *) ;;
    esac
  done
}

dump_rescue() {
  local ts; ts="$(date +%Y%m%d-%H%M%S)"
  docker exec "$CID" bash -lc '
    cd /work
    git bundle create /tmp/cage.bundle --all >/dev/null 2>&1 || true
    git add -A >/dev/null 2>&1 || true
    git diff --cached > /tmp/cage-uncommitted.patch 2>/dev/null || true
  ' || true
  local bundle="$PROJ/cage-rescue-$ts.bundle"
  local patch="$PROJ/cage-rescue-$ts-uncommitted.patch"
  docker cp "$CID:/tmp/cage.bundle"            "$bundle" >/dev/null 2>&1 && log "Wrote $bundle"  || true
  docker cp "$CID:/tmp/cage-uncommitted.patch" "$patch"  >/dev/null 2>&1 && log "Wrote $patch"   || true
  echo
  echo "  Recover committed work:   git fetch \"$bundle\" '*:*'   (or: git pull \"$bundle\" <branch>)"
  echo "  Recover uncommitted work: git apply \"$patch\""
}

# --- Commands -------------------------------------------------------------------------
cmd_run() {
  need_docker
  # Git context — informational only. The cage always gets a usable repo in /work (spin_up
  # runs `git init` there if needed), so cage works in any dir without prompting or touching
  # your host. .git is copied only when THIS dir is a repo root.
  local root; root="$(git -C "$PROJ" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -z "$root" ]]; then
    warn "Not a git repo — the cage will 'git init' /work. Add a remote inside to push, or use the rescue dump."
  elif [[ "$root" != "$PROJ" ]]; then
    warn "This is a SUBDIRECTORY of the repo at: $root"
    warn "Only this dir is copied (a fresh repo in the cage — no history/remote). Run cage at the repo root for full git."
  fi
  if ! have_login; then
    log "First run: Claude will ask you to log in once, in the session below (saved to '$CLAUDE_VOLUME' and reused next time)."
  fi
  local tag; tag="$(ensure_image)"
  spin_up "$tag"

  # Build the agent's appended system prompt from the breadcrumb + port guidance.
  local first="${PORTS%% *}" sysnote=""
  [[ "$BREADCRUMB" == 1 ]] && sysnote="$SYS_NOTE"
  if [[ -n "$PORTS" ]]; then
    local p
    for p in $PORTS; do log "🌐 Published http://localhost:$p  → have the server bind 0.0.0.0:$p"; done
    sysnote="${sysnote:+$sysnote

}WEB SERVERS: bind to 0.0.0.0 on port ${first} (env PORT=${first} is set). ONLY host port(s) [${PORTS}] are published and reachable by the user at http://localhost:${first}. A server bound to 127.0.0.1, or to any other port, is NOT reachable from the user's machine — verifying it from inside the container proves nothing. Do not report a server as working unless it is bound to 0.0.0.0:${first}."
  fi

  log "Launching Claude Code (--dangerously-skip-permissions)…"
  local cargs=( --dangerously-skip-permissions )
  [[ -n "$sysnote" ]] && cargs+=( --append-system-prompt "$sysnote" )
  cargs+=( "$@" )
  trap '' INT                       # let Claude own Ctrl-C; don't kill cage
  docker exec -it "$CID" bash -lc 'cd /work && exec claude "$@"' bash "${cargs[@]}" || true
  trap cleanup INT
  rescue_work
  write_breadcrumb
}

cmd_shell() {
  need_docker
  local tag; tag="$(ensure_image)"
  spin_up "$tag"
  log "Opening a shell in the cage (Claude is installed; run 'claude --dangerously-skip-permissions')…"
  trap '' INT
  docker exec -it "$CID" bash -lc 'cd /work && exec bash' || true
  trap cleanup INT
  rescue_work
  write_breadcrumb
}

cmd_build()   { need_docker; local rt; rt="$(detect_runtimes "$PROJ")"; build_image "$(image_tag "$rt")" "$rt"; }
cmd_rebuild() { need_docker; local rt; rt="$(detect_runtimes "$PROJ")"; DOCKER_BUILDKIT=1 docker build --no-cache --build-arg CAGE_RUNTIMES="$rt" --build-arg NODE_MAJOR="$NODE_MAJOR" -t "$(image_tag "$rt")" "$HERE/templates"; }

cmd_detect() {
  echo "Project:  $PROJ"
  echo "Runtimes: $(detect_runtimes "$PROJ" || true)"
  echo "Image:    $(image_tag "$(detect_runtimes "$PROJ")")"
  echo "Installs:"; detect_install "$PROJ" | sed 's/^/  /'
}

cmd_gh_token() {
  command -v gh >/dev/null 2>&1 || die "gh not installed (brew install gh, then gh auth login)."
  local tok; tok="$(gh auth token 2>/dev/null || true)"
  [[ -n "$tok" ]] || die "No token from gh — run 'gh auth login' first."
  set_config GH_TOKEN "$tok"
  log "Imported GH_TOKEN into cage.config (len ${#tok}; not shown). Enables 'git push' + 'gh' in the cage."
}

cmd_login() { need_docker; do_login "$(ensure_base_image)"; }

# --- One-time interactive setup -------------------------------------------------------
# Prompt goes to the tty (>&2); only the chosen value goes to stdout (so $(...) captures it).
_ask()   { local p="$1" d="${2:-}" a=""; if [[ -n "$d" ]]; then printf '  %s [%s]: ' "$p" "$d" >&2; else printf '  %s: ' "$p" >&2; fi; read -r a </dev/tty || a=""; printf '%s' "${a:-$d}"; }
_yesno() { local a=""; printf '  %s [Y/n]: ' "$1" >&2; read -r a </dev/tty || a=""; case "${a:-y}" in y|Y|yes|YES) return 0;; *) return 1;; esac; }

cmd_setup() {
  need_docker
  log "cage setup — one-time configuration (writes $HERE/cage.config, gitignored)."
  echo

  # 1. cage.config
  if [[ -f "$HERE/cage.config" ]]; then warn "cage.config already exists — updating it in place."
  else cp "$HERE/cage.config.example" "$HERE/cage.config"; log "Created cage.config from the example."; fi

  # 2. GitHub token (for git push + gh from inside the cage)
  if command -v gh >/dev/null 2>&1 && gh auth token >/dev/null 2>&1; then
    set_config GH_TOKEN "$(gh auth token)"
    log "Imported GH_TOKEN from gh (enables push + PRs in the cage)."
  else
    warn "gh not logged in — skipping GitHub token. Run 'gh auth login' then 'cage gh-token' later."
  fi

  # 3. Git commit identity (default to your host git config)
  local dn de
  dn="$(_ask 'Git commit name'  "$(git config --global user.name  2>/dev/null)")"
  de="$(_ask 'Git commit email' "$(git config --global user.email 2>/dev/null)")"
  [[ -n "$dn" ]] && set_config GIT_USER_NAME  "$dn"
  [[ -n "$de" ]] && set_config GIT_USER_EMAIL "$de"

  # 4. Claude auth
  echo; echo "  Claude auth:  1) subscription login (Pro/Max)   2) API key"
  local choice; choice="$(_ask 'Choose 1 or 2' '1')"
  if [[ "$choice" == 2 ]]; then
    local k=""; printf '  Paste ANTHROPIC_API_KEY (hidden): '; read -rs k </dev/tty || k=""; echo
    [[ -n "$k" ]] && { set_config ANTHROPIC_API_KEY "$k"; ANTHROPIC_API_KEY="$k"; log "Saved ANTHROPIC_API_KEY."; } || warn "No key entered — skipped."
  else
    if _yesno "Log in to Claude now?"; then do_login "$(ensure_base_image)"; else log "Skipped — cage will prompt for login on first run."; fi
  fi

  # 5. PATH symlink
  if ! command -v cage >/dev/null 2>&1 || [[ "$(command -v cage)" != "$HERE/cage" && ! -L "$(command -v cage 2>/dev/null)" ]]; then
    local d; for d in /opt/homebrew/bin /usr/local/bin "$HOME/bin"; do
      if [[ -d "$d" && -w "$d" ]]; then
        if _yesno "Symlink 'cage' onto your PATH at $d/cage?"; then ln -sf "$HERE/cage" "$d/cage" && log "Symlinked $d/cage"; fi
        break
      fi
    done
  fi

  echo; log "Setup complete."; echo; cmd_doctor
}

cmd_doctor() {
  need_docker && log "Docker daemon: OK"
  if [[ -f "$HERE/cage.config" ]]; then log "cage.config: present"; else warn "cage.config missing — cp cage.config.example cage.config"; fi
  local base; base="$(image_tag "")"
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then log "Claude auth: ANTHROPIC_API_KEY set"
  elif image_exists "$base" && volume_has_login "$base" >/dev/null 2>&1; then log "Claude auth: logged in (shared volume '$CLAUDE_VOLUME')"
  elif docker volume inspect "$CLAUDE_VOLUME" >/dev/null 2>&1; then warn "Claude auth: volume exists but no login detected — run 'cage login'"
  else warn "Claude auth: not set up yet — run 'cage setup' (or 'cage login')"; fi
  if [[ -n "${GH_TOKEN:-}" ]]; then log "GitHub: GH_TOKEN set (push + PRs work)"; else warn "GitHub: no GH_TOKEN — run 'cage gh-token' to enable push/PRs"; fi
}

cmd_ps() {
  need_docker
  echo "Cage containers:"; docker ps -a --filter "name=cage_" --format '  {{.Names}}\t{{.Status}}' || true
  echo "Cage images:";     docker images "cage" --format '  {{.Repository}}:{{.Tag}}\t{{.Size}}' || true
}

cmd_nuke() {
  need_docker
  warn "Removing ALL cage containers, images, and the shared Claude login volume."
  printf '  Proceed? [y/N] '; local a=""; read -r a || a=n
  [[ "$a" == y || "$a" == Y ]] || { log "Aborted."; return 0; }
  docker ps -aq --filter "name=cage_" | xargs -r docker rm -f >/dev/null 2>&1 || true
  docker images -q "cage" | sort -u | xargs -r docker rmi -f >/dev/null 2>&1 || true
  docker volume rm "$CLAUDE_VOLUME" >/dev/null 2>&1 || true
  log "Nuked. Next 'cage' rebuilds from scratch and re-asks for Claude login."
}

cmd_config() {
  if [[ -f "$HERE/cage.config" ]]; then echo "$HERE/cage.config"
  else warn "No cage.config yet. Create it with:"; echo "  cp \"$HERE/cage.config.example\" \"$HERE/cage.config\""; fi
}

usage() {
  cat <<EOF
cage — throwaway Docker box that runs Claude Code recklessly, safely.

USAGE
  cage [args]        Build/reuse this dir's image, copy it into an ephemeral container,
                     and launch Claude Code (--dangerously-skip-permissions). Extra args
                     pass through to claude. On exit, rescues any unpushed work.
                     (First ever run auto-prompts a one-time Claude login.)
  cage shell         Same spin-up, but drop into a bash shell instead of Claude.

SETUP
  cage setup         One-time interactive bootstrap: writes cage.config (GitHub token, git
                     identity, Claude auth) and offers to symlink cage onto your PATH.
  cage gh-token      Import your GitHub token from 'gh' into cage.config (enables push/PRs).
  cage login         (Re)do the Claude login into the shared volume. Usually automatic.
  cage doctor        Check Docker, config, Claude auth, and GitHub token.
  cage config        Print the path to cage.config.

IMAGES
  cage detect        Show the detected runtimes / image tag / install commands for this dir.
  cage build         Build (cache-reusing) this dir's image without launching.
  cage rebuild       Build with --no-cache (fresh toolchains).
  cage ps            List cage containers and images.
  cage nuke          Remove all cage containers, images, and the Claude login volume.

First run on a machine:  cage setup
EOF
}

case "${1:-}" in
  ""|run)            shift || true; cmd_run "$@" ;;
  shell|console)     cmd_shell ;;
  setup)             cmd_setup ;;
  gh-token)          cmd_gh_token ;;
  login)             cmd_login ;;
  doctor)            cmd_doctor ;;
  detect)            cmd_detect ;;
  build)             cmd_build ;;
  rebuild)           cmd_rebuild ;;
  ps)                cmd_ps ;;
  nuke)              cmd_nuke ;;
  config)            cmd_config ;;
  -h|--help|help)    usage ;;
  *)                 die "unknown command: $1  (run 'cage help')" ;;
esac
