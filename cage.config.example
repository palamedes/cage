# cage.config — per-machine secrets & preferences. NEVER commit this file.
#
#   cp cage.config.example cage.config        # then edit
#
# `cage` sources this from its own install dir, so it's found no matter which project
# directory you run `cage` in. It's gitignored — keep your secrets here, not in the repo.

# --- Claude Code auth (pick ONE) ------------------------------------------------------
# (a) API key — zero prompts, bills per-token to your Anthropic Console account:
# export ANTHROPIC_API_KEY="sk-ant-..."
# (b) Subscription login — leave the key unset and run `cage login` once; it's stored in
#     the shared 'cage_claude' volume and reused by every cage (no host creds exposed).

# --- GitHub — enables `git push` (HTTPS) and `gh` (PRs) from inside the cage -----------
# Easiest: run `cage gh-token` to import from your Mac's gh. Or paste a repo-scoped PAT:
# export GH_TOKEN="ghp_..."

# --- Git commit identity used INSIDE the cage for the agent's commits ------------------
# export GIT_USER_NAME="Your Name"
# export GIT_USER_EMAIL="you@example.com"

# --- Behavior toggles (defaults shown) ------------------------------------------------
# Pre-install detected dependencies (bundle/yarn/pip/…) before launching Claude:
# export CAGE_PREINSTALL=1
# Copy your global ~/.claude/CLAUDE.md + skills/ into the cage (never your credentials):
# export CAGE_SYNC_GLOBAL_CLAUDE=1
# Also copy ~/.claude/settings.json (off by default — its hooks/paths may not exist in-cage):
# export CAGE_SYNC_SETTINGS=0
# Claude UI theme inside the cage. Blank mirrors the theme you run on the host so the agent
# matches your terminal (otherwise Claude falls back to its non-ANSI default — too light in an
# ANSI terminal). Set explicitly to override, e.g. dark-ansi / light-ansi / dark / light:
# export CAGE_CLAUDE_THEME=""
# Leave a .cage breadcrumb in each project (what past cage sessions did here). The agent is
# asked to append a dated summary; cage adds a mechanical line (commits/branches). Auto-
# excluded from git. Set to 0 to disable:
# export CAGE_BREADCRUMB=1
# export CAGE_NOTE_FILE=.cage
# Host port(s) published from the cage so a server you start inside is reachable from your
# Mac at http://localhost:<port>. Space-separated; set to "" to publish nothing. PORT is set
# inside the container to the first one, and the agent is told to bind 0.0.0.0:<port>.
# export CAGE_PORTS="4000"
# Base Node major version used for Claude Code itself:
# export CAGE_NODE_MAJOR=22
# Name of the shared Docker volume holding the Claude login:
# export CAGE_CLAUDE_VOLUME=cage_claude
# Heavy, reinstallable dirs kept OUT of the copy into the container:
# export CAGE_COPY_EXCLUDES="node_modules .venv venv vendor/bundle .bundle target .next .nuxt __pycache__ .pytest_cache .gradle .DS_Store"
